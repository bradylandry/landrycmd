<Layout title="NYC Family Trip · June 2026">
  <div class="trip-page">
    <!-- scroll progress -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <section class="trip-hero">
      <!-- floating particles -->
      <div class="particles" aria-hidden="true">
        {Array.from({ length: 30 }).map((_, i) => (
          <span class={`particle p${i % 6}`} style={`--i: ${i}; --x: ${(i * 137) % 100}%; --d: ${10 + (i % 6) * 2}s; --delay: ${(i % 10) * -1.7}s;`}></span>
        ))}
      </div>
      <!-- subtle skyline -->
      <svg class="skyline" viewBox="0 0 1440 200" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,200 L0,140 L40,140 L40,100 L80,100 L80,150 L120,150 L120,90 L160,90 L160,130 L200,130 L200,70 L240,70 L240,40 L280,40 L280,110 L320,110 L320,80 L360,80 L360,140 L400,140 L400,100 L440,100 L440,60 L460,60 L460,30 L480,30 L480,90 L520,90 L520,130 L560,130 L560,80 L600,80 L600,40 L640,40 L640,110 L680,110 L680,150 L720,150 L720,100 L760,100 L760,50 L780,50 L780,20 L800,20 L800,90 L840,90 L840,130 L880,130 L880,80 L920,80 L920,120 L960,120 L960,70 L1000,70 L1000,140 L1040,140 L1040,100 L1080,100 L1080,60 L1120,60 L1120,140 L1160,140 L1160,90 L1200,90 L1200,50 L1240,50 L1240,130 L1280,130 L1280,80 L1320,80 L1320,140 L1360,140 L1360,100 L1400,100 L1400,150 L1440,150 L1440,200 Z" fill="rgba(56,189,248,0.06)"/>
      </svg>
      <div class="trip-hero-inner">
        <div class="hero-eyebrow">🗽 NEW YORK CITY</div>
        <h1>NYC Family Trip</h1>
        <p class="dates">June 2 – 8, 2026 · Brady, Stacy, Blake, Karsyn, Emrie</p>
        <div class="countdown" id="countdown">
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-days">--</span>
            <span class="countdown-label">days</span>
          </div>
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-hours">--</span>
            <span class="countdown-label">hrs</span>
          </div>
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-mins">--</span>
            <span class="countdown-label">min</span>
          </div>
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-secs">--</span>
            <span class="countdown-label">sec</span>
          </div>
        </div>
      </div>
    </section>

    <nav class="quick-nav">
      <a href="#flights">✈️ Flights</a>
      <a href="#hotel">🏨 Hotel</a>
      <a href="#weather">🌤️ Weather</a>
      <a href="#map">🗺️ Map</a>
      <a href="#tue">Tue</a>
      <a href="#wed">Wed</a>
      <a href="#thu">🎭 Thu</a>
      <a href="#fri">Fri</a>
      <a href="#sat">Sat</a>
      <a href="#sun">⚾ Sun</a>
      <a href="#mon">Mon</a>
      <a href="#alternates">🔀 Alternates</a>
      <a href="#reservations">📋 Bookings</a>
    </nav>

    <div class="trip-wrap">
      <!-- WEATHER -->
      <section class="trip-section" id="weather">
        <h2><span class="section-icon">🌤️</span> Trip Forecast</h2>
        <p style="color:var(--text-dim); margin-top:-0.5rem; margin-bottom:1.25rem; font-size:0.9rem;">
          Avg June NYC — highs 78-83°F, occasional afternoon showers. Pack a light layer + small umbrella.
        </p>
        <div class="weather-grid">
          {weather.map((w) => (
            <div class="weather-day">
              <div class="weather-day-label">{w.day}</div>
              <div class="weather-day-date">{w.date}</div>
              <div class="weather-icon">{w.sky}</div>
              <div class="weather-temps">
                <span class="weather-high">{w.high}°</span>
                <span class="weather-low">{w.low}°</span>
              </div>
              <div class="weather-note">{w.note}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- NYC OVERVIEW MAP -->
      <section class="trip-section" id="map">
        <h2><span class="section-icon">🗺️</span> Where We'll Be</h2>
        <div class="nyc-map-wrap">
          <svg class="nyc-map" viewBox="0 0 600 800" aria-hidden="true">
            <!-- river/water -->
            <rect x="0" y="0" width="600" height="800" fill="#0a1428"/>
            <!-- East River -->
            <path d="M380,0 Q420,200 400,400 Q380,600 440,800 L600,800 L600,0 Z" fill="#0d1f3a"/>
            <!-- Hudson River -->
            <path d="M0,0 L150,0 Q120,200 130,400 Q140,600 110,800 L0,800 Z" fill="#0d1f3a"/>
            <!-- Manhattan land outline -->
            <path d="M150,0 L380,0 Q420,200 400,400 Q380,600 440,800 L110,800 Q140,600 130,400 Q120,200 150,0 Z" fill="#1a2438" stroke="rgba(56,189,248,0.15)" stroke-width="1"/>
            <!-- street grid hint -->
            <g stroke="rgba(56,189,248,0.08)" stroke-width="0.5">
              <line x1="150" y1="100" x2="400" y2="100"/>
              <line x1="140" y1="200" x2="410" y2="200"/>
              <line x1="135" y1="300" x2="415" y2="300"/>
              <line x1="130" y1="400" x2="420" y2="400"/>
              <line x1="135" y1="500" x2="425" y2="500"/>
              <line x1="140" y1="600" x2="430" y2="600"/>
              <line x1="220" y1="0" x2="220" y2="800"/>
              <line x1="270" y1="0" x2="270" y2="800"/>
              <line x1="320" y1="0" x2="320" y2="800"/>
            </g>

            <!-- Brooklyn -->
            <path d="M440,800 L600,800 L600,500 Q500,520 460,560 Q440,640 440,800 Z" fill="#1a2438" stroke="rgba(56,189,248,0.15)"/>
            <text x="540" y="640" fill="rgba(255,255,255,0.4)" font-size="11" font-family="sans-serif">BROOKLYN</text>
            <text x="540" y="655" fill="rgba(255,255,255,0.3)" font-size="9" font-family="sans-serif">DUMBO</text>

            <!-- The Bronx (top right) -->
            <path d="M380,0 Q500,40 600,80 L600,0 Z" fill="#1a2438" stroke="rgba(56,189,248,0.15)"/>
            <text x="500" y="50" fill="rgba(255,255,255,0.4)" font-size="11" font-family="sans-serif">BRONX</text>

            <!-- Statue of Liberty -->
            <g class="map-pin pin-1" transform="translate(180, 760)">
              <circle r="14" fill="rgba(238,53,46,0.2)"/>
              <circle r="6" fill="#ee352e"/>
              <text x="0" y="-22" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">Statue</text>
            </g>

            <!-- 9/11 -->
            <g class="map-pin pin-1" transform="translate(225, 720)">
              <circle r="11" fill="rgba(238,53,46,0.15)"/>
              <circle r="5" fill="#ee352e"/>
            </g>

            <!-- Chinatown / Little Italy -->
            <g class="map-pin pin-1" transform="translate(265, 700)">
              <circle r="11" fill="rgba(0,147,60,0.15)"/>
              <circle r="5" fill="#00933c"/>
              <text x="0" y="-12" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">Chinatown</text>
            </g>

            <!-- Brooklyn Bridge -->
            <g class="map-pin pin-2" transform="translate(310, 690)">
              <circle r="11" fill="rgba(0,147,60,0.15)"/>
              <circle r="5" fill="#00933c"/>
            </g>

            <!-- SoHo -->
            <g class="map-pin pin-3" transform="translate(245, 640)">
              <circle r="11" fill="rgba(108,190,69,0.18)"/>
              <circle r="5" fill="#6cbe45"/>
              <text x="0" y="-12" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">SoHo</text>
            </g>

            <!-- Hotel (NoMad / 27th) -->
            <g class="map-pin pin-4" transform="translate(265, 480)">
              <circle r="18" fill="rgba(236,72,153,0.2)"/>
              <circle r="8" fill="#ec4899" stroke="#fff" stroke-width="2"/>
