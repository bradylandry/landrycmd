---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;

// helper to build a Google Maps query link
const map = (q: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;
const transit = (dest: string) =>
  `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(
    "The Evelyn Hotel, 7 East 27th Street, New York, NY",
  )}&destination=${encodeURIComponent(dest)}&travelmode=transit`;
const tel = (n: string) => `tel:${n.replace(/[^+\d]/g, "")}`;

const flights = [
  {
    label: "Outbound · Leg 1",
    num: "DL 5308",
    cabin: "Delta Main",
    date: "Tue Jun 2",
    from: { code: "LFT", city: "Lafayette", time: "3:12 PM CDT" },
    to: { code: "ATL", city: "Atlanta", time: "6:00 PM EDT" },
    seats: "14A · 14B · 14C · 14D · 15B",
  },
  {
    label: "Outbound · Leg 2",
    num: "DL 490",
    cabin: "Delta Main",
    date: "Tue Jun 2",
    from: { code: "ATL", city: "Atlanta", time: "8:00 PM EDT" },
    to: { code: "LGA", city: "LaGuardia · Term C", time: "10:20 PM EDT" },
    seats: "22A · 22B · 22C · 22D · 22E",
  },
  {
    label: "Return · Leg 1",
    num: "DL 2227",
    cabin: "Delta Main",
    date: "Mon Jun 8",
    from: { code: "JFK", city: "Kennedy Intl", time: "8:40 AM EDT" },
    to: { code: "ATL", city: "Atlanta", time: "11:14 AM EDT" },
    seats: "23C · 23D · 23E · 24A · 24B",
  },
  {
    label: "Return · Leg 2",
    num: "DL 5308",
    cabin: "Delta Main",
    date: "Mon Jun 8",
    from: { code: "ATL", city: "Atlanta", time: "1:51 PM EDT" },
    to: { code: "LFT", city: "Lafayette", time: "2:39 PM CDT" },
    seats: "14A · 14B · 14C · 14D · 15B",
