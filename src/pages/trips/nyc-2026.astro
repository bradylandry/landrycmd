  <script is:inline>
    // ---- COUNTDOWN ----
    const target = new Date("2026-06-02T15:12:00-05:00").getTime();
    const dEl = document.getElementById("cd-days");
    const hEl = document.getElementById("cd-hours");
    const mEl = document.getElementById("cd-mins");
    const sEl = document.getElementById("cd-secs");

    function tick() {
      const now = Date.now();
      let diff = Math.max(0, target - now);
      const d = Math.floor(diff / 86400000);
      diff -= d * 86400000;
      const h = Math.floor(diff / 3600000);
      diff -= h * 3600000;
      const m = Math.floor(diff / 60000);
      diff -= m * 60000;
      const s = Math.floor(diff / 1000);
      if (dEl) dEl.textContent = String(d);
      if (hEl) hEl.textContent = String(h).padStart(2, "0");
      if (mEl) mEl.textContent = String(m).padStart(2, "0");
      if (sEl) sEl.textContent = String(s).padStart(2, "0");
    }
    tick();
    setInterval(tick, 1000);

    // ---- DAY CARDS REVEAL ON SCROLL ----
    const cards = document.querySelectorAll(".day-card");
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      cards.forEach((c) => io.observe(c));
    } else {
      cards.forEach((c) => c.classList.add("visible"));
    }

    // ---- SCROLL PROGRESS ----
    const progressEl = document.getElementById("scrollProgress");
    function updateProgress() {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
      if (progressEl) progressEl.style.transform = `scaleX(${pct / 100})`;
    }
    document.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();

    // ---- SMOOTH SCROLL ----
    document.querySelectorAll('.quick-nav a[href^="#"]').forEach((a) => {
      a.addEventListener("click", (e) => {
        const id = a.getAttribute("href").slice(1);
        const el = document.getElementById(id);
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    // ---- VOTING ----
    let voteState = {}; // { optionId: [voter, voter, ...] }

    function applyVoteState() {
      // update each vote button's "voted" class + each row's tally
      document.querySelectorAll(".vote-btn").forEach((btn) => {
        const opt = btn.dataset.option;
        const voter = btn.dataset.voter;
        const list = voteState[opt] || [];
        if (list.includes(voter)) {
          btn.classList.add("voted");
        } else {
          btn.classList.remove("voted");
        }
      });
      // for each vote-row, append a tally count
      document.querySelectorAll(".vote-row").forEach((row) => {
        const opt = row.dataset.optionId;
        const list = voteState[opt] || [];
        let tally = row.querySelector(".vote-tally");
        if (!tally) {
          tally = document.createElement("span");
          tally.className = "vote-tally";
          row.appendChild(tally);
        }
        tally.textContent =
          list.length === 0
            ? "no votes"
            : list.length === 1
              ? "1 vote"
              : `${list.length} votes`;
      });
      renderSummary();
    }

    function renderSummary() {
      const summary = document.getElementById("voteSummary");
      if (!summary) return;
      const totals = Object.entries(voteState)
        .filter(([_, list]) => list.length > 0)
        .sort((a, b) => b[1].length - a[1].length);
      if (totals.length === 0) {
        summary.innerHTML = '<span class="vote-summary-empty">No votes yet — click your name on any option to vote.</span>';
        return;
      }
      const [topId, topVoters] = totals[0];
      const titleEl = document.querySelector(`[data-option-id="${topId}"]`)
        ?.closest(".alt-card, .alt-row")
        ?.querySelector(".alt-card-title, .alt-row-title");
      const topTitle = titleEl ? titleEl.textContent.trim() : topId;
      const others = totals.length - 1;
      summary.innerHTML = `<span class="vote-summary-leader">🏆 Leader: <strong>${topTitle}</strong> · ${topVoters.length} ${topVoters.length === 1 ? "vote" : "votes"} (${topVoters.join(", ")})</span>${others > 0 ? `<span class="vote-summary-other"> · ${others} other ${others === 1 ? "option has" : "options have"} votes</span>` : ""}`;
    }

    async function loadVotes() {
      try {
        const res = await fetch("/api/trips/votes", { cache: "no-store" });
        const data = await res.json();
        if (data.ok) {
          voteState = data.votes || {};
          applyVoteState();
        }
      } catch (e) {
        // silent — user might be offline
      }
    }

    async function castVote(optionId, voter) {
      // optimistic update
      const list = voteState[optionId] || [];
      const had = list.includes(voter);
      voteState[optionId] = had
        ? list.filter((v) => v !== voter)
        : [...list, voter];
      applyVoteState();
      try {
        const res = await fetch("/api/trips/vote", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ optionId, voter, action: "toggle" }),
        });
        const data = await res.json();
        if (!data.ok) {
          // rollback
          voteState[optionId] = list;
          applyVoteState();
        }
      } catch (e) {
        // rollback on network failure
        voteState[optionId] = list;
        applyVoteState();
      }
    }

    document.querySelectorAll(".vote-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const opt = btn.dataset.option;
        const voter = btn.dataset.voter;
        if (opt && voter) castVote(opt, voter);
      });
    });

    // initial load + auto-refresh every 30s while page is visible
    loadVotes();
    setInterval(() => {
      if (!document.hidden) loadVotes();
    }, 30000);
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) loadVotes();
    });
  </script>
</Layout>

<style>
  @import "../../styles/trip.css";
</style>
