        detail: "~5 blocks. 222 W 51st St. Box Office #: TF88GC3. Order #: 206502940-7757062. 5 tickets.",
        actions: [
          { label: "🗺️ Gershwin Theatre", href: map("Gershwin Theatre 222 W 51st St"), type: "" },
