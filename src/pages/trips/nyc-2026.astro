  { item: "🥟 Nom Wah dim sum", date: "Jun 6 · 3pm", status: "todo", cost: "~$100", conf: "—" },
  { item: "🍕 Lombardi's", date: "Jun 6 · 6pm", status: "todo", cost: "~$150", conf: "—" },
  { item: "🍽️ Sunday post-game dinner", date: "Jun 7 · 6:30pm", status: "todo", cost: "~$200", conf: "—" },
];

// Average June NYC weather (placeholder — swap for live API later)
const weather = [
  { day: "Tue", date: "Jun 2", high: 78, low: 64, sky: "☀️", note: "Arrival evening" },
  { day: "Wed", date: "Jun 3", high: 80, low: 65, sky: "⛅", note: "Liberty / 9/11" },
  { day: "Thu", date: "Jun 4", high: 82, low: 67, sky: "☀️", note: "Wicked night" },
  { day: "Fri", date: "Jun 5", high: 79, low: 65, sky: "⛅", note: "Bike + SoHo" },
  { day: "Sat", date: "Jun 6", high: 81, low: 66, sky: "🌤️", note: "Brooklyn Bridge" },
  { day: "Sun", date: "Jun 7", high: 83, low: 68, sky: "☀️", note: "Yankees" },
  { day: "Mon", date: "Jun 8", high: 81, low: 67, sky: "☀️", note: "Departure" },
];
---

<Layout title="NYC Family Trip · June 2026">
  <div class="trip-page">
    <!-- scroll progress -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <section class="trip-hero">
      <!-- floating particles -->
      <div class="particles" aria-hidden="true">
        {Array.from({ length: 30 }).map((_, i) => (
          <span class={`particle p${i % 6}`} style={`--i: ${i}; --x: ${(i * 137) % 100}%; --d: ${10 + (i % 6) * 2}s; --delay: ${(i % 10) * -1.7}s;`}></span>
        ))}
      </div>
      <!-- subtle skyline -->
      <svg class="skyline" viewBox="0 0 1440 200" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,200 L0,140 L40,140 L40,100 L80,100 L80,150 L120,150 L120,90 L160,90 L160,130 L200,130 L200,70 L240,70 L240,40 L280,40 L280,110 L320,110 L320,80 L360,80 L360,140 L400,140 L400,100 L440,100 L440,60 L460,60 L460,30 L480,30 L480,90 L520,90 L520,130 L560,130 L560,80 L600,80 L600,40 L640,40 L640,110 L680,110 L680,150 L720,150 L720,100 L760,100 L760,50 L780,50 L780,20 L800,20 L800,90 L840,90 L840,130 L880,130 L880,80 L920,80 L920,120 L960,120 L960,70 L1000,70 L1000,140 L1040,140 L1040,100 L1080,100 L1080,60 L1120,60 L1120,140 L1160,140 L1160,90 L1200,90 L1200,50 L1240,50 L1240,130 L1280,130 L1280,80 L1320,80 L1320,140 L1360,140 L1360,100 L1400,100 L1400,150 L1440,150 L1440,200 Z" fill="rgba(56,189,248,0.06)"/>
      </svg>
      <div class="trip-hero-inner">
        <div class="hero-eyebrow">🗽 NEW YORK CITY</div>
        <h1>NYC Family Trip</h1>
        <p class="dates">June 2 – 8, 2026 · Brady, Wife, Blake, Karsyn, Emrie</p>
        <div class="countdown" id="countdown">
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-days">--</span>
            <span class="countdown-label">days</span>
          </div>
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-hours">--</span>
            <span class="countdown-label">hrs</span>
          </div>
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-mins">--</span>
            <span class="countdown-label">min</span>
          </div>
          <div class="countdown-segment">
            <span class="countdown-num" id="cd-secs">--</span>
            <span class="countdown-label">sec</span>
          </div>
        </div>
      </div>
    </section>

    <nav class="quick-nav">
      <a href="#flights">✈️ Flights</a>
      <a href="#hotel">🏨 Hotel</a>
      <a href="#weather">🌤️ Weather</a>
      <a href="#map">🗺️ Map</a>
      <a href="#tue">Tue</a>
      <a href="#wed">Wed</a>
      <a href="#thu">🎭 Thu</a>
      <a href="#fri">Fri</a>
      <a href="#sat">Sat</a>
      <a href="#sun">⚾ Sun</a>
      <a href="#mon">Mon</a>
      <a href="#reservations">📋 Bookings</a>
    </nav>

    <div class="trip-wrap">
      <!-- WEATHER -->
      <section class="trip-section" id="weather">
        <h2><span class="section-icon">🌤️</span> Trip Forecast</h2>
        <p style="color:var(--text-dim); margin-top:-0.5rem; margin-bottom:1.25rem; font-size:0.9rem;">
          Avg June NYC — highs 78-83°F, occasional afternoon showers. Pack a light layer + small umbrella.
        </p>
        <div class="weather-grid">
          {weather.map((w) => (
            <div class="weather-day">
              <div class="weather-day-label">{w.day}</div>
              <div class="weather-day-date">{w.date}</div>
              <div class="weather-icon">{w.sky}</div>
              <div class="weather-temps">
                <span class="weather-high">{w.high}°</span>
                <span class="weather-low">{w.low}°</span>
              </div>
              <div class="weather-note">{w.note}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- NYC OVERVIEW MAP -->
      <section class="trip-section" id="map">
        <h2><span class="section-icon">🗺️</span> Where We'll Be</h2>
        <div class="nyc-map-wrap">
          <svg class="nyc-map" viewBox="0 0 600 800" aria-hidden="true">
            <!-- river/water -->
            <rect x="0" y="0" width="600" height="800" fill="#0a1428"/>
            <!-- East River -->
            <path d="M380,0 Q420,200 400,400 Q380,600 440,800 L600,800 L600,0 Z" fill="#0d1f3a"/>
            <!-- Hudson River -->
            <path d="M0,0 L150,0 Q120,200 130,400 Q140,600 110,800 L0,800 Z" fill="#0d1f3a"/>
            <!-- Manhattan land outline -->
            <path d="M150,0 L380,0 Q420,200 400,400 Q380,600 440,800 L110,800 Q140,600 130,400 Q120,200 150,0 Z" fill="#1a2438" stroke="rgba(56,189,248,0.15)" stroke-width="1"/>
            <!-- street grid hint -->
            <g stroke="rgba(56,189,248,0.08)" stroke-width="0.5">
              <line x1="150" y1="100" x2="400" y2="100"/>
              <line x1="140" y1="200" x2="410" y2="200"/>
              <line x1="135" y1="300" x2="415" y2="300"/>
              <line x1="130" y1="400" x2="420" y2="400"/>
              <line x1="135" y1="500" x2="425" y2="500"/>
              <line x1="140" y1="600" x2="430" y2="600"/>
              <line x1="220" y1="0" x2="220" y2="800"/>
              <line x1="270" y1="0" x2="270" y2="800"/>
              <line x1="320" y1="0" x2="320" y2="800"/>
            </g>

            <!-- Brooklyn -->
            <path d="M440,800 L600,800 L600,500 Q500,520 460,560 Q440,640 440,800 Z" fill="#1a2438" stroke="rgba(56,189,248,0.15)"/>
            <text x="540" y="640" fill="rgba(255,255,255,0.4)" font-size="11" font-family="sans-serif">BROOKLYN</text>
            <text x="540" y="655" fill="rgba(255,255,255,0.3)" font-size="9" font-family="sans-serif">DUMBO</text>

            <!-- The Bronx (top right) -->
            <path d="M380,0 Q500,40 600,80 L600,0 Z" fill="#1a2438" stroke="rgba(56,189,248,0.15)"/>
            <text x="500" y="50" fill="rgba(255,255,255,0.4)" font-size="11" font-family="sans-serif">BRONX</text>

            <!-- Statue of Liberty -->
            <g class="map-pin pin-1" transform="translate(180, 760)">
              <circle r="14" fill="rgba(238,53,46,0.2)"/>
              <circle r="6" fill="#ee352e"/>
              <text x="0" y="-22" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">Statue</text>
            </g>

            <!-- 9/11 -->
            <g class="map-pin pin-1" transform="translate(225, 720)">
              <circle r="11" fill="rgba(238,53,46,0.15)"/>
              <circle r="5" fill="#ee352e"/>
            </g>

            <!-- Chinatown / Little Italy -->
            <g class="map-pin pin-1" transform="translate(265, 700)">
              <circle r="11" fill="rgba(0,147,60,0.15)"/>
              <circle r="5" fill="#00933c"/>
              <text x="0" y="-12" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">Chinatown</text>
            </g>

            <!-- Brooklyn Bridge -->
            <g class="map-pin pin-2" transform="translate(310, 690)">
              <circle r="11" fill="rgba(0,147,60,0.15)"/>
              <circle r="5" fill="#00933c"/>
            </g>

            <!-- SoHo -->
            <g class="map-pin pin-3" transform="translate(245, 640)">
              <circle r="11" fill="rgba(108,190,69,0.18)"/>
              <circle r="5" fill="#6cbe45"/>
              <text x="0" y="-12" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">SoHo</text>
            </g>

            <!-- Hotel (NoMad / 27th) -->
            <g class="map-pin pin-4" transform="translate(265, 480)">
              <circle r="18" fill="rgba(236,72,153,0.2)"/>
              <circle r="8" fill="#ec4899" stroke="#fff" stroke-width="2"/>
              <text x="0" y="-22" text-anchor="middle" fill="#fff" font-size="11" font-weight="bold" font-family="sans-serif">🏨 HOTEL</text>
            </g>

            <!-- Times Square / Gershwin -->
            <g class="map-pin pin-5" transform="translate(245, 410)">
              <circle r="13" fill="rgba(255,99,25,0.2)"/>
              <circle r="6" fill="#ff6319"/>
              <text x="0" y="-14" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">🎭 Wicked</text>
            </g>

            <!-- Top of the Rock -->
            <g class="map-pin pin-5" transform="translate(265, 395)">
              <circle r="11" fill="rgba(255,99,25,0.15)"/>
              <circle r="5" fill="#ff6319"/>
            </g>

            <!-- Grand Central -->
            <g class="map-pin pin-5" transform="translate(290, 415)">
              <circle r="11" fill="rgba(255,99,25,0.15)"/>
              <circle r="5" fill="#ff6319"/>
              <text x="14" y="3" fill="#fff" font-size="9" font-family="sans-serif">Grand Central</text>
            </g>

            <!-- Central Park -->
            <rect x="225" y="270" width="80" height="100" fill="rgba(108,190,69,0.15)" stroke="rgba(108,190,69,0.3)" stroke-width="1"/>
            <text x="265" y="320" text-anchor="middle" fill="rgba(108,190,69,0.7)" font-size="10" font-family="sans-serif">Central</text>
            <text x="265" y="333" text-anchor="middle" fill="rgba(108,190,69,0.7)" font-size="10" font-family="sans-serif">Park</text>

            <!-- Yankee Stadium (Bronx) -->
            <g class="map-pin pin-6" transform="translate(420, 100)">
              <circle r="14" fill="rgba(238,53,46,0.18)"/>
              <circle r="6" fill="#ee352e"/>
              <text x="0" y="-12" text-anchor="middle" fill="#fff" font-size="10" font-family="sans-serif">⚾ Yankees</text>
            </g>

            <!-- LGA & JFK indicators -->
            <g class="map-pin pin-1" transform="translate(550, 250)">
              <circle r="9" fill="rgba(56,189,248,0.2)"/>
              <text x="0" y="3" text-anchor="middle" fill="#38bdf8" font-size="10" font-family="sans-serif" font-weight="bold">LGA</text>
            </g>
            <g class="map-pin pin-7" transform="translate(580, 600)">
              <circle r="9" fill="rgba(56,189,248,0.2)"/>
              <text x="0" y="3" text-anchor="middle" fill="#38bdf8" font-size="10" font-family="sans-serif" font-weight="bold">JFK</text>
            </g>
          </svg>
          <div class="map-legend">
            <div class="legend-item"><span class="legend-dot" style="background:#ec4899"></span>Hotel</div>
            <div class="legend-item"><span class="legend-dot" style="background:#ee352e"></span>Wed/Sun</div>
            <div class="legend-item"><span class="legend-dot" style="background:#ff6319"></span>Thu</div>
            <div class="legend-item"><span class="legend-dot" style="background:#6cbe45"></span>Fri</div>
            <div class="legend-item"><span class="legend-dot" style="background:#00933c"></span>Sat</div>
          </div>
        </div>
      </section>

      <!-- FLIGHTS -->
      <section class="trip-section" id="flights">
        <h2><span class="section-icon">✈️</span> Flights</h2>
        <div class="flights-grid">
          {flights.map((f) => (
            <div class="flight-card">
              <div class="flight-card-head">
                <span class="flight-num">{f.num} · {f.cabin}</span>
                <span>{f.date}</span>
              </div>
              <div class="flight-route">
                <div class="flight-airport">
                  <div class="flight-airport-code">{f.from.code}</div>
                  <div class="flight-time">{f.from.time}</div>
                </div>
                <div class="flight-arrow">
                  <svg viewBox="0 0 80 28" aria-hidden="true">
                    <path d="M2 14 Q40 4 78 14" stroke="var(--trip-accent)" stroke-width="1" fill="none" stroke-dasharray="3 3" opacity="0.4"/>
                    <g class="plane-along-arc">
                      <path d="M-6 0 L4 -2 L7 0 L4 2 Z" fill="var(--trip-accent)" transform="translate(0,0)"/>
                    </g>
                  </svg>
                </div>
                <div class="flight-airport">
                  <div class="flight-airport-code">{f.to.code}</div>
                  <div class="flight-time">{f.to.time}</div>
                </div>
              </div>
              <div class="flight-meta">
                <span><strong>{f.label}</strong></span>
                <span class="flight-seats">{f.seats}</span>
              </div>
            </div>
          ))}
        </div>
        <p style="margin-top:1.25rem; font-size:0.9rem; color:var(--text-dim);">
          ⚠️ <strong>Heads up</strong>: return is from <strong>JFK</strong>, not LGA.
          Plan ~1 hr Uber XL ride from hotel — leave by 6:00 AM.
        </p>
      </section>

      <!-- HOTEL -->
      <section class="trip-section" id="hotel">
        <h2><span class="section-icon">🏨</span> Hotel</h2>
        <div class="hotel-card">
          <div class="hotel-card-inner">
            <div class="hotel-tagline">Where we're staying</div>
            <div class="hotel-name">The Evelyn Hotel · NoMad</div>
            <p style="color:var(--text-dim); margin: 0 0 1.25rem;">
              Art Deco boutique hotel · 29th & Madison · 5 blocks from Macy's Herald Square
            </p>
            <div class="hotel-meta">
              <div class="hotel-meta-item">
                <div class="hotel-meta-label">Address</div>
                <div>7 East 27th Street<br />New York, NY 10016</div>
              </div>
              <div class="hotel-meta-item">
                <div class="hotel-meta-label">Phone</div>
                <div><a href={tel("+12125458000")} style="color:var(--trip-pink);">(212) 545-8000</a></div>
              </div>
              <div class="hotel-meta-item">
                <div class="hotel-meta-label">Check-in</div>
                <div>3:00 PM · Tue Jun 2</div>
              </div>
              <div class="hotel-meta-item">
                <div class="hotel-meta-label">Check-out</div>
                <div>12:00 PM · Mon Jun 8</div>
              </div>
            </div>
            <div style="display:flex; flex-wrap:wrap; gap: 0.5rem;">
              <a class="chip" href={gmap("The Evelyn Hotel 7 East 27th Street New York")}>🗺️ Google Maps</a>
              <a class="chip chip-grey" href={amap("The Evelyn Hotel 7 East 27th Street New York")}>🍎 Apple Maps</a>
              <a class="chip chip-pink" href="https://www.theevelyn.com/">🌐 theevelyn.com</a>
              <a class="chip chip-yellow" href={tel("+12125458000")}>📞 Call hotel</a>
            </div>
          </div>
        </div>
      </section>

      <!-- DAY-BY-DAY -->
      <section class="trip-section">
        <h2><span class="section-icon">📅</span> Day by Day</h2>
        <div class="days-stack">
          {days.map((d) => (
            <article id={d.id} class="day-card" style={`--day-color: ${d.color};`}>
              <div class="day-card-head">
                <div class="day-card-date">
                  <div class="day-glyph" set:html={d.glyph}></div>
                  <div>
                    <div class="day-card-day">{d.day}</div>
                    <div class="day-card-num">{d.date}</div>
                  </div>
                </div>
                <span class="day-card-theme">{d.theme}</span>
              </div>
              <div class="day-card-body">
                <ul class="day-timeline">
                  {d.events.map((e) => (
                    <li class="day-event">
                      <div>
                        <span class="day-event-time">{e.time}</span>
                        <span class="day-event-title">{e.title}</span>
                      </div>
                      {e.detail && <div class="day-event-detail">{e.detail}</div>}
                      {e.actions && (
                        <div class="day-event-actions">
                          {e.actions.map((a: any) => (
                            <a class={`chip ${a.type || ""}`} href={a.href}>
                              {a.label}
                            </a>
                          ))}
                        </div>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- HIGHLIGHT: WICKED -->
      <section class="trip-section">
        <article class="highlight-card wicked-card">
          <div class="sparkle-layer" aria-hidden="true">
            {Array.from({ length: 12 }).map((_, i) => (
              <span class="sparkle" style={`--x: ${(i * 41) % 100}%; --y: ${(i * 67) % 100}%; --d: ${3 + (i % 4)}s; --delay: ${(i % 7) * -0.5}s;`}></span>
            ))}
          </div>
          <div class="highlight-content">
            <div style="color:var(--trip-purple); font-size:0.8rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.5rem;">
              Thursday Jun 4 · 7:00 PM
            </div>
            <div class="highlight-title">Wicked</div>
            <p style="color:rgba(255,255,255,0.85); margin:0.5rem 0 1.25rem;">
              Gershwin Theatre · 222 W 51st St · 5 tickets · Box office <code>TF88GC3</code>
            </p>
            <div style="display:flex; flex-wrap:wrap; gap: 0.5rem;">
              <a class="chip" href={gmap("Gershwin Theatre 222 W 51st St")}>🗺️ Gershwin Theatre</a>
              <a class="chip chip-grey" href={amap("Gershwin Theatre 222 W 51st St")}>🍎 Apple Maps</a>
              <a class="chip chip-pink" href="https://wickedthemusical.com/">🌐 Show site</a>
            </div>
          </div>
        </article>
      </section>

      <!-- HIGHLIGHT: YANKEES -->
      <section class="trip-section">
        <article class="highlight-card yankees-card">
          <div class="highlight-content">
            <div style="color:rgba(255,255,255,0.7); font-size:0.8rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.5rem;">
              Sunday Jun 7 · 1:35 PM
            </div>
            <div class="highlight-title" style="color:#fff;">Yankees vs Red Sox</div>
            <p style="color:rgba(255,255,255,0.85); margin:0.5rem 0 1.25rem;">
              Yankee Stadium · Bronx · Premium rivalry game · Target Grandstand Infield 411-413 or 423-425, ~$80-100/seat
            </p>
            <div style="display:flex; flex-wrap:wrap; gap: 0.5rem;">
              <a class="chip" href={gmap("Yankee Stadium Bronx")}>🗺️ Yankee Stadium</a>
              <a class="chip chip-grey" href={amap("Yankee Stadium Bronx")}>🍎 Apple Maps</a>
              <a class="chip" href={transit("Yankee Stadium 1 E 161st St Bronx")}>🚇 From hotel</a>
              <a class="chip chip-pink" href="https://www.tickpick.com/mlb/new-york-yankees-tickets/">🎟️ TickPick</a>
              <a class="chip chip-pink" href="https://seatgeek.com/new-york-yankees-tickets/6-7-2026-bronx-new-york-yankee-stadium/mlb/17691552">🎟️ SeatGeek</a>
            </div>
          </div>
        </article>
      </section>

      <!-- RESERVATIONS -->
      <section class="trip-section" id="reservations">
        <h2><span class="section-icon">📋</span> Bookings Status</h2>
        <table class="res-table">
          <thead>
            <tr>
              <th>Item</th>
              <th>When</th>
              <th>Status</th>
              <th>Cost</th>
            </tr>
          </thead>
          <tbody>
            {reservations.map((r) => (
              <tr>
                <td>{r.item}</td>
                <td style="color:var(--text-dim); font-size:0.85rem;">{r.date}</td>
                <td>
                  <span class={`res-status ${r.status}`}>
                    {r.status === "booked" ? "✓ Booked" : r.status === "todo" ? "⏳ To book" : "○ Optional"}
                  </span>
                </td>
                <td style="color:var(--text-dim); font-size:0.85rem;">{r.cost}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <!-- LOGISTICS NOTES -->
      <section class="trip-section">
        <h2><span class="section-icon">🚇</span> Logistics</h2>
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
          <div class="logistics-tip">
            <div style="color:var(--trip-accent); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.5rem;">Subway</div>
            <p style="margin:0; color:var(--text-dim); font-size:0.9rem; line-height:1.6;">
              OMNY tap-to-pay (any contactless card or Apple Pay). After 12 taps in 7 days, the rest of the week is free.
            </p>
          </div>
          <div class="logistics-tip">
            <div style="color:var(--trip-pink); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.5rem;">LGA Arrival</div>
            <p style="margin:0; color:var(--text-dim); font-size:0.9rem; line-height:1.6;">
              Tue 10:20 PM Terminal C → Uber XL only (5 + bags). ~$55-70 to hotel. Skip AirTrain.
            </p>
          </div>
          <div class="logistics-tip">
            <div style="color:var(--trip-yellow); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.5rem;">JFK Departure</div>
            <p style="margin:0; color:var(--text-dim); font-size:0.9rem; line-height:1.6;">
              Mon 8:40 AM. JFK is ~1 hr away. Leave hotel 6:00 AM. Suitcases packed Sat night.
            </p>
          </div>
          <div class="logistics-tip">
            <div style="color:var(--trip-green); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.5rem;">Bikes</div>
            <p style="margin:0; color:var(--text-dim); font-size:0.9rem; line-height:1.6;">
              Citi Bike is 16+ only. Rent from a Central Park shop for the family — ~$15-20/hr/bike, kids' sizes + helmets.
            </p>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    // ---- COUNTDOWN ----
    const target = new Date("2026-06-02T15:12:00-05:00").getTime();
    const dEl = document.getElementById("cd-days");
    const hEl = document.getElementById("cd-hours");
    const mEl = document.getElementById("cd-mins");
    const sEl = document.getElementById("cd-secs");

    function tick() {
      const now = Date.now();
      let diff = Math.max(0, target - now);
      const d = Math.floor(diff / 86400000);
      diff -= d * 86400000;
      const h = Math.floor(diff / 3600000);
      diff -= h * 3600000;
      const m = Math.floor(diff / 60000);
      diff -= m * 60000;
      const s = Math.floor(diff / 1000);
      if (dEl) dEl.textContent = String(d);
      if (hEl) hEl.textContent = String(h).padStart(2, "0");
      if (mEl) mEl.textContent = String(m).padStart(2, "0");
      if (sEl) sEl.textContent = String(s).padStart(2, "0");
    }
    tick();
    setInterval(tick, 1000);

    // ---- DAY CARDS REVEAL ON SCROLL ----
    const cards = document.querySelectorAll(".day-card");
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      cards.forEach((c) => io.observe(c));
    } else {
      cards.forEach((c) => c.classList.add("visible"));
    }

    // ---- SCROLL PROGRESS ----
    const progressEl = document.getElementById("scrollProgress");
    function updateProgress() {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
      if (progressEl) progressEl.style.transform = `scaleX(${pct / 100})`;
    }
    document.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();

    // ---- SMOOTH SCROLL ----
    document.querySelectorAll('.quick-nav a[href^="#"]').forEach((a) => {
      a.addEventListener("click", (e) => {
        const id = a.getAttribute("href").slice(1);
        const el = document.getElementById(id);
        if (el) {
          e.preventDefault();
          el.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  </script>
</Layout>

