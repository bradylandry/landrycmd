  { item: "Flights LFT→LGA", date: "Jun 2", status: "booked", cost: "—", conf: "DL 5308 / 490" },
  { item: "Flights JFK→LFT", date: "Jun 8", status: "booked", cost: "—", conf: "DL 2227 / 5308" },
