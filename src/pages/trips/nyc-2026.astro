// ===== Map / link helpers =====
const HOTEL = "The Evelyn Hotel, 7 East 27th Street, New York, NY 10016";

const gmap = (q: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(q)}`;
const amap = (q: string) =>
  `https://maps.apple.com/?q=${encodeURIComponent(q)}`;
const transit = (dest: string, origin: string = HOTEL) =>
  `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(origin)}&destination=${encodeURIComponent(dest)}&travelmode=transit`;
const walk = (dest: string, origin: string) =>
  `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(origin)}&destination=${encodeURIComponent(dest)}&travelmode=walking`;
const tel = (n: string) => `tel:${n.replace(/[^+\d]/g, "")}`;

// shorthand: every venue gets google + apple + transit-from-hotel by default
const venue = (name: string, query?: string) => {
  const q = query || name;
  return [
    { label: `🗺️ ${name}`, href: gmap(q), type: "" },
    { label: `🍎 Apple Maps`, href: amap(q), type: "chip-grey" },
    { label: `🚇 From hotel`, href: transit(q), type: "" },
  ];
};

