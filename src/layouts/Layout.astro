---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = "Independent software shop. AI infrastructure, algorithmic trading, and mobile health apps. Run by Brady Landry.", noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const isPrivate = noindex || Astro.url.pathname.startsWith("/trips/");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {isPrivate && <meta name="robots" content="noindex,nofollow,noarchive" />}
    {!isPrivate && <link rel="canonical" href={canonical} />}

    <!-- Open Graph / social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="landrycmd" />
    <meta name="twitter:card" content="summary" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="brand">landrycmd</a>
        <nav>
          <a href="/#products">Products</a>
          <a href="/#about">About</a>
          <a href="/writing/">Writing</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <div>
          <strong>landrycmd</strong>
          &nbsp;·&nbsp;
          <a href="mailto:support@landrycmd.com">support@landrycmd.com</a>
          &nbsp;·&nbsp;
          Louisiana, USA
        </div>
        <div>
          <a href="/privacy">Privacy</a>
          &nbsp;·&nbsp;
          <a href="/terms">Terms</a>
          &nbsp;·&nbsp;
          <span>EIN 41-4998290</span>
        </div>
      </div>
    </footer>
  </body>
</html>
